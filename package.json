{
  "name": "tablecardify",
  "version": "0.1.0",
  "description": "Transform HTML tables into responsive cards below a configurable breakpoint.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/tablecardify.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "responsive-table",
    "table-to-cards",
    "bootstrap",
    "cards",
    "mobile"
  ],
  "author": "Antonio Di Lorenzo",
  "license": "MIT",
  "sideEffects": [
    "./dist/tablecardify.css"
  ],
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
